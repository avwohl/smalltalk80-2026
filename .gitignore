Local.xcconfig

# Build outputs
*.o
*.a
*.dSYM/
build/
build-*/
cmake-build-*/

# Scratch runners/logs at repo root (leading underscore = throwaway)
/_*.bat
/_*.ps1
/_*.log

# Claude Code session state (per-checkout runtime, never shared)
.claude/scheduled_tasks.lock

# Package outputs
*.deb
*.rpm

# Xcode
DerivedData/
*.xcworkspace
Frameworks/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.swiftpm/
.build/
Packages/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# Smalltalk-80 image artifacts (not redistributed — fetched separately)
*.image
*.changes
*.sources
/images/
/test-images/

# Reference implementation checkouts (cloned separately)
/reference/

# Archives
*.zip
*.tar.gz

# Crash dumps
*.dmp

# Python
*.pyc
__pycache__/
